# =====================================================================
# Spritz — environment variables
# Copy to .env.local and fill in. NEVER commit real values to this file
# or to .env.local.
# =====================================================================

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Supabase ----------
# Get from: https://supabase.com/dashboard/project/_/settings/api-keys
# Use the NEW key types (legacy anon/service_role JWTs are deprecated and
# can't be rotated):
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  → sb_publishable_...  (safe for browsers)
#   SUPABASE_SERVICE_ROLE_KEY      → sb_secret_...       (server only, bypasses RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Clerk ----------
# Get from: https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=                  # for /api/webhooks/clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ---------- Stripe ----------
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=                 # for /api/webhooks/stripe
STRIPE_PRICE_ID_PRO_MONTHLY=           # price_xxx for $4.99/mo (Pro Monthly, 7-day trial applied in code)
STRIPE_PRICE_ID_PRO_ANNUAL=            # price_xxx for $29.99/yr (Pro Annual, billed upfront, no trial)
STRIPE_PRICE_ID_PRO_LIFETIME=          # price_xxx for $89 one-time (Pro Lifetime, non-recurring / "payment" mode)

# ---------- RevenueCat (mobile in-app purchases — App Store / Play) ----------
# Web uses Stripe (above); the iOS/Android shells use StoreKit / Play Billing
# via RevenueCat, which posts to /api/webhooks/revenuecat to grant Pro.
REVENUECAT_WEBHOOK_AUTH=                # exact value you set as the webhook Authorization header in RevenueCat
NEXT_PUBLIC_REVENUECAT_IOS_KEY=         # RevenueCat public SDK key (Apple) — used by the native client
NEXT_PUBLIC_REVENUECAT_ANDROID_KEY=    # RevenueCat public SDK key (Google) — for the later Android build

# ---------- Vision (PRD §7 — Q1 spike picks the winner) ----------
OPENAI_API_KEY=                        # GPT-4o vision (primary)
GOOGLE_VISION_API_KEY=                 # Google Vision (cost fallback)
# OCR cost knobs — defaults are gpt-4o + auto detail. After an accuracy
# eval, flip to gpt-4o-mini + low for ~10x cheaper scans:
# SCAN_OCR_MODEL=gpt-4o-mini
# SCAN_OCR_DETAIL=low

# ---------- Affiliate links ----------
SCENTBIRD_AFFILIATE_ID=
FRAGRANCENET_AFFILIATE_ID=
NORDSTROM_AFFILIATE_ID=

# ---------- Analytics (Q9, default PostHog) ----------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- Rate limits (PRD §7) ----------
SCAN_RATE_LIMIT_ANON=10                # per day per IP
SCAN_RATE_LIMIT_FREE=50                # per day per signed-in free user
SCAN_RATE_LIMIT_PRO=300                # per day per Pro user (generous anti-abuse ceiling; GPT-4o vision is the pricey call)
SCAN_GLOBAL_DAILY_BUDGET=2000          # hard daily cap across ALL scans (model spend ceiling)

# AI generation ceiling — paid dupes + consensus (model called only on cache miss)
AI_GEN_RATE_LIMIT=20                   # generations per user per window (burst guard)
AI_GEN_RATE_WINDOW_MIN=10              # window length in minutes for AI_GEN_RATE_LIMIT
# Hard backstop for total AI spend: set a spend limit in your model provider's
# dashboard (OpenAI today; Anthropic if you migrate the AI features to Claude).
