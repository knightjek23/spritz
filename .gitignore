# dependencies — any node_modules anywhere (root, scraper, editorial,
# trends-collector, etc.). If a nested one is already tracked, untrack it:
#   git rm -r --cached <path>/node_modules
**/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# npm is the package manager of record — block other lockfiles from
# reappearing (root had both package-lock.json and pnpm-lock.yaml, which
# makes Vercel's package-manager detection nondeterministic)
pnpm-lock.yaml
yarn.lock

# testing
/coverage

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — NEVER commit
.env
.env*.local
.env.local
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo

# scraper output (raw HTML + parsed JSON, gitignored — rebuild from source)
/scraper/data/raw/
/scraper/data/parsed/
/scraper/data/*.log

# supabase
supabase/.branches
supabase/.temp

# IDE
.vscode/
.idea/

# screenshots: regenerated locally, never committed
/screenshots/
/.auth/
scripts/*.log
