# scraper/.env.example
# Service-role key — bypasses RLS, lets the scraper bulk-insert.
# NEVER commit this file. NEVER deploy this scraper.

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Pacing knobs (seconds)
# Cloudflare blocks this scraper aggressively at 2-5s pacing. 8-15s is the
# tested-safe minimum. Slow first, speed up only after a clean run.
DELAY_MIN=8
DELAY_MAX=15

# Headed mode (visible Chrome window) is much harder for Cloudflare to detect
# as automation. Default false (= headed). Override to "true" for headless if
# you've confirmed it works for your IP.
HEADLESS=false

# How many fragrances to scrape this run
SCRAPE_LIMIT=10000

# ----- Discovery (click-loop) configuration -----
# The Fragrantica search page uses a "+ Show more results" button instead of
# URL pagination. discover() opens this URL once and then clicks the button
# in a loop until SCRAPE_LIMIT URLs are collected.
#
# Override these in .env if Fragrantica's structure changes — no code edit.

DISCOVER_URL=https://www.fragrantica.com/search/

# Visible text on the load-more button. Playwright matches case-insensitively
# and substring, so "Show more results" handles "+ Show more results" too.
DISCOVER_BUTTON_TEXT=Show more results

# CSS selector for fragrance result links on the search page.
# Defaults to anchors whose href matches /perfume/.
DISCOVER_RESULT_SELECTOR=a[href*="/perfume/"]

# After clicking, how long to wait for new results before assuming we're done.
# Bump this if you have a slow connection or Fragrantica is laggy.
DISCOVER_CLICK_WAIT_MS=4000

# Stop after this many consecutive clicks that yield no new URLs.
DISCOVER_NO_GROWTH_LIMIT=3
