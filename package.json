{
  "name": "spritz",
  "version": "0.1.0",
  "private": true,
  "description": "Spritz — scan a bottle, know everything about it.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:server-onclick": "node scripts/check-server-onclick.mjs",
    "prebuild": "npm run check:server-onclick",
    "db:migrate": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "screenshots:auth": "node scripts/screenshots/auth.mjs",
    "screenshots": "node scripts/screenshots/capture.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^5.7.0",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.0",
    "next": "14.2.33",
    "openai": "^4.67.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^17.1.0",
    "svix": "^1.36.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.33",
    "playwright": "^1.60.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
